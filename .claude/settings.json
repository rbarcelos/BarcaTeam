{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Search",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "SendMessage",
      "TeamCreate",
      "TeamDelete",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(pytest *)",
      "Bash(curl *)",
      "Bash(tmux *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(tree *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(env *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(uvicorn *)",
      "Bash(docker *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "teammateMode": "tmux",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
